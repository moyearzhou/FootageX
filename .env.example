# FootageX stores runtime settings in outputs/video_workbench/immich_settings.json.
# This file is only a reference for the values you will enter in the web UI.

IMMICH_BASE_URL=http://your-immich-host:2283
IMMICH_API_KEY=
OPENAI_BASE_URL=https://aiapi.zotpaper.cn/v1
OPENAI_MODEL=gpt-5.4-mini

# Optional server binding. Docker Compose sets HOST=0.0.0.0 automatically.
HOST=127.0.0.1
PORT=5173

# Optional Docker build base image. Change this if Docker Hub is slow in your network.
NODE_IMAGE=node:20-alpine

# MySQL storage used by Docker Compose. Change these before exposing the service.
MYSQL_IMAGE=mysql:8.4
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=footagex
MYSQL_USER=footagex
MYSQL_PASSWORD=change-me
